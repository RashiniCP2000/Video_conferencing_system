PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/videoconf
JWT_SECRET=change-this-to-a-long-random-string-in-production
CLIENT_ORIGIN=http://localhost:5173

# Google OAuth2 Credentials for Calendar Integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/callback

# SMTP Settings for Mail notifications (optional, fallback to Ethereal)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="VideoConf System" <no-reply@videoconf.com>
